# Google Antigravity / Gemini API Key
GOOGLE_API_KEY=your_google_api_key_here

# Optional: Antigravity-specific key (if different from GOOGLE_API_KEY)
ANTIGRAVITY_API_KEY=

# Optional: Default model choice for agy CLI (e.g. gemini-3.5-flash)
# AGY_MODEL=gemini-3.5-flash

# Optional: Container timezone
TZ=Europe/Berlin
